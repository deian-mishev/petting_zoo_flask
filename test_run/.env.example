# Flask
FLASK_KEY=change-me-in-production
FLASK_RUN_PORT=5000

# Video rendering
AGENT_VID_WIDTH=160
AGENT_VID_HEIGHT=210

# MongoDB — matches docker-compose service
MONGO_DB_URI=mongodb://mongo:27017/rl_db

# Keycloak — matches realm-export.json
OAUTH2_SERVER_URL=http://keycloak:8080
OAUTH2_REALM=petting-zoo
OAUTH2_CLIENT_ID=petting-zoo-client
OAUTH2_CLIENT_SECRET=dev-secret-change-in-prod

# ML model (optional — leave blank to skip loading)
ATTARI_PRO_MODEL=
ATTARI_PRO_WEIGHTS_PATH=
